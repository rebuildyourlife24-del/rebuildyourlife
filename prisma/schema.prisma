generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER              // Normale gebruiker in Fase 1-4
  OPERATOR          // Dagelijkse admin (klantenservice, testen)
  SUPREME_OVERSEER  // God Modus (Volledige systeemcontrole)
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIAL
}

model User {
  id             String             @id @default(cuid())
  email          String             @unique
  password       String?
  firstName      String?
  lastName       String?
  role           Role               @default(USER)
  phase          Int                @default(1) // Fase 1 t/m 4 (De Progression Wall)
  
  // Abonnement & Mollie
  mollieCustomerId String?          @unique
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  // Relaties
  bankAccounts   BankAccount[]
  franchises     Franchise[]
  tradingBot     TradingBot?
  opportunities  Opportunity[] @relation("AssignedOpportunities")
  
  // Ambassador Netwerk Relaties
  ambassadorNode     AmbassadorNetwork? @relation("AmbassadorNode")
  ambassadorChildren AmbassadorNetwork[] @relation("AmbassadorParent")
  
  subAgreements      CommissionAgreement[] @relation("AgreementSub")
  parentAgreements   CommissionAgreement[] @relation("AgreementParent")
  
  // Nieuwe Relaties (AI OS Master Update)
  // tickets            Ticket[]        @relation("UserTickets")
  // assignedTickets    Ticket[]        @relation("AssignedTickets")
  // emailCampaigns     EmailCampaign[]
  // posts              Post[]
  // comments           Comment[]
  // likes              Like[]
}

// Actie 1: Bank Koppeling (PSD2) Portaal
model BankAccount {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  bankName       String        // bijv. "ING", "Rabobank"
  iban           String        @unique // Geanonimiseerd opslaan in productie!
  balance        Float         @default(0.0)
  currency       String        @default("EUR")
  
  // Nordigen / GoCardless / Plaid integratie ID
  externalBankId String?       @unique 
  
  lastSyncedAt   DateTime      @default(now())
  createdAt      DateTime      @default(now())

  transactions   Transaction[]
}

model Transaction {
  id             String      @id @default(cuid())
  bankAccountId  String
  bankAccount    BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  
  amount         Float
  currency       String      @default("EUR")
  description    String
  date           DateTime
  category       String?     // Boodschappen, Luxe, Onzin, Vaste Lasten (Orion AI categorie)
  isAnalyzed     Boolean     @default(false) // Heeft de AI dit al gelezen?

  createdAt      DateTime    @default(now())
}

// Actie 2: Mollie API & 25% Tolpoort (E-Commerce Franchises)
model Franchise {
  id             String      @id @default(cuid())
  ownerId        String
  owner          User        @relation(fields: [ownerId], references: [id])
  
  storeName      String      @unique
  domainUrl      String      // bijv. "shop1.ai-henksemler.nl"
  niche          String      // bijv. "Luxe Horloges", "Sauna's"
  
  isActive       Boolean     @default(true)
  totalRevenue   Float       @default(0.0)
  platformCut    Float       @default(0.0) // De 25% die naar de Supreme Overseer gaat
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  
  // Relaties naar PR & Omega
  prCampaigns    PRCampaign[]
  omegaSite      OmegaSite?
}

// Omega Web Builder & PR Sector
model OmegaSite {
  id             String      @id @default(cuid())
  franchiseId    String      @unique
  franchise      Franchise   @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  
  templateUsed   String      @default("HIGH_CONVERSION_LUXURY_V1")
  conversionRate Float       @default(0.0)
  isLive         Boolean     @default(true)
  
  deployedAt     DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model PRCampaign {
  id             String      @id @default(cuid())
  franchiseId    String
  franchise      Franchise   @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  
  campaignName   String      // bijv. "Dubai Lifestyle Hooks"
  platform       String      @default("TIKTOK")
  totalViews     Int         @default(0)
  status         String      @default("ACTIVE") // ACTIVE, VIRAL, COMPLETED
  
  // Gekoppelde Media vanuit de 'Centrale Materialen'
  mediaPath      String?     // bijv. "/materials/Render_Dubai_001.mp4"
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

// Alpha Algo-Trading Sector
model TradingBot {
  id             String      @id @default(cuid())
  userId         String      @unique
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  exchange       String      @default("BINANCE") // of BYBIT, KRAKEN
  apiKey         String?     // Moet encrypted worden opgeslagen
  apiSecret      String?     
  
  status         String      @default("IDLE") // IDLE, TRADING, EMERGENCY_STOP
  mode           String      @default("CONSERVATIVE") // CONSERVATIVE, APEX_AGGRESSIVE
  allocatedFunds Float       @default(0.0) // Het budget vanuit de kluis
  currentPnl     Float       @default(0.0)
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  trades         TradeRecord[]
}

model TradeRecord {
  id             String      @id @default(cuid())
  botId          String
  bot            TradingBot  @relation(fields: [botId], references: [id], onDelete: Cascade)
  
  symbol         String      // bijv. "BTC/USDT", "SOL/USDT"
  type           String      // "LONG", "SHORT"
  entryPrice     Float
  exitPrice      Float?
  leverage       Int         @default(1)
  
  pnlAmount      Float       @default(0.0)
  pnlPercentage  Float       @default(0.0)
  
  status         String      @default("OPEN") // OPEN, CLOSED
  
  openedAt       DateTime    @default(now())
  closedAt       DateTime?
}

// Apex Land Acquisition Sector
model LandAsset {
  id             String      @id @default(cuid())
  
  targetName     String      // bijv. "Verlaten Bedrijventerrein A4", "Weesgrond Perceel 89"
  location       String      
  assetType      String      // ORPHAN_LAND, TAX_LIEN, DISTRESSED_COMMERCIAL
  
  estimatedValue Float       // Wat is de marktwaarde?
  acquisitionCost Float      // Wat kost het om de claim/tax-lien te kopen?
  
  status         String      @default("SCANNING") // SCANNING, TARGET_LOCKED, CLAIM_PENDING, ACQUIRED
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  legalClaims    LegalClaim[]
}

model LegalClaim {
  id             String      @id @default(cuid())
  assetId        String
  asset          LandAsset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  notary         String?     // Naam van de gekoppelde notaris/kantoor
  documentHash   String?     // AES-256 hash van het AI-gegenereerde eigendomsdocument
  status         String      @default("GENERATING") // GENERATING, SENT_TO_NOTARY, APPROVED
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

// The Shadow Syndicate
model IntellectualProperty {
  id             String      @id @default(cuid())
  
  targetName     String      // De verlopen merknaam of patent naam
  category       String      // TRADEMARK, PATENT, DOMAIN
  registry       String      // BOIP, EUIPO, WIPO
  
  estimatedValue Float       // Wat is de potentiële licentiewaarde?
  registrationCost Float     // Wat kost het ons om het nu te claimen?
  
  status         String      @default("SCANNING") // SCANNING, CLAIMABLE, CLAIMED, LICENSED
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model TaxEntity {
  id             String      @id @default(cuid())
  
  country        String      // bijv. "Estonia", "UAE (Dubai)", "Delaware"
  entityType     String      // E_RESIDENCY, LLC, FZCO
  taxRate        Float       // 0.0 voor Dubai, 20.0 voor Estland etc.
  
  currentBalance Float       @default(0.0) // Het vermogen geparkeerd in deze jurisdictie
  status         String      @default("ACTIVE") // ACTIVE, DORMANT, ROUTING_FUNDS
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model EspionageReport {
  id             String      @id @default(cuid())
  
  targetCompany  String      // Concurrent naam
  sector         String      // E-commerce, Tech, etc.
  
  intelligenceLevel String   // LOW, MEDIUM, HIGH, CRITICAL_VULNERABILITY
  reportHash     String?     // PDF/Data hash
  marketValue    Float       // Waarvoor kunnen we deze info B2B verkopen?
  
  status         String      @default("GATHERING") // GATHERING, COMPILED, FOR_SALE, SOLD
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

// Stellar Ascension Sector
model OrbitalNode {
  id             String      @id @default(cuid())
  
  satelliteId    String      // bijv. "STARLINK-3921", "BLOCKSTREAM-NODE-4"
  orbitType      String      // LEO, MEO, GEO
  function       String      // DATA_VAULT, COMMS_RELAY, SENSOR
  
  storageCapacity Float      // GBs
  uplinkSpeed    Float       // Mbps
  
  status         String      @default("ONLINE") // ONLINE, ORBIT_SHIFT, OFFLINE
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model AerospaceAsset {
  id             String      @id @default(cuid())
  
  targetName     String      // "SpaceX Equity", "Asteroid Psyche 16 Mining Claim"
  assetType      String      // EQUITY, SPECULATIVE_CLAIM, RARE_MINERALS
  
  estimatedValue Float       
  riskLevel      String      // EXTREME, HIGH, MODERATE
  
  status         String      @default("TRACKING") // TRACKING, INVESTED, CLAIMED
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Opportunity {
  id                String    @id @default(uuid())
  title             String
  description       String
  payout            Float
  category          String    // e.g., "LEAD_GEN", "SEO", "SALES", "SUPPORT"
  status            String    @default("AVAILABLE") // "AVAILABLE", "IN_PROGRESS", "COMPLETED"
  
  // AI Autonomous Economy Fields
  executionType     String    @default("CLIENT_BROKERED") // "AI_AUTONOMOUS" | "CLIENT_BROKERED"
  commissionRate    Float     @default(0.0) // Percentage Orion takes
  guaranteedSuccess Boolean   @default(false) // 100% ROI check for AI
  
  assignedToId      String?
  assignedTo        User?     @relation("AssignedOpportunities", fields: [assignedToId], references: [id])
  
  createdAt         DateTime  @default(now())
  expiresAt         DateTime?

  @@index([status])
  @@index([category])
  @@index([assignedToId])
  @@index([executionType])
}

model AiSharedMemory {
  id         String   @id @default(uuid())
  sourceAi   String   @map("source_ai")
  visibleTo  String[] @default(["hermes", "orion", "qwen"]) @map("visible_to")
  memoryType String   @map("memory_type")
  content    String   @db.Text
  context    Json     @default("{}") @map("context")
  
  // Compliance & Data Isolation (GDPR)
  userId     String   @map("user_id")
  tenantId   String   @default("default_tenant") @map("tenant_id")
  containsPII Boolean @default(false) @map("contains_pii")
  
  importance Float
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("ai_shared_memory")
}

// ============================================================================
// VERDIENMODEL 10: AMBASSADEUR / SYNDICATE NETWERK (THE ELITE CLOSERS)
// ============================================================================

model AmbassadorNetwork {
  id             String      @id @default(cuid())
  userId         String      @unique // De ambassadeur zelf
  user           User        @relation("AmbassadorNode", fields: [userId], references: [id], onDelete: Cascade)
  
  parentUserId   String?     // De ambassadeur die déze ambassadeur heeft binnengehaald
  parentUser     User?       @relation("AmbassadorParent", fields: [parentUserId], references: [id])
  
  referralCode   String      @unique // Bijv: "HENK-ELITE-99"
  totalEarnings  Float       @default(0.0) // Totaal verdiend aan commissies
  
  status         String      @default("ACTIVE") // ACTIVE, BANNED
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // De verdeelsleutels
  commissionAgreements CommissionAgreement[] @relation("SubSellerAgreements")
  parentAgreements     CommissionAgreement[] @relation("ParentSellerAgreements")
}

model CommissionAgreement {
  id             String      @id @default(cuid())
  
  parentUserId   String
  parentUser     User        @relation("AgreementParent", fields: [parentUserId], references: [id])
  
  subUserId      String
  subUser        User        @relation("AgreementSub", fields: [subUserId], references: [id])
  
  parentSplitPercentage Float @default(40.0) // Bijv 40% van de €500
  subSplitPercentage    Float @default(60.0) // Bijv 60% van de €500
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  
  AmbassadorNetwork AmbassadorNetwork? @relation("SubSellerAgreements", fields: [subUserId], references: [userId], map: "sub_agreement_network")
  AmbassadorParent  AmbassadorNetwork? @relation("ParentSellerAgreements", fields: [parentUserId], references: [userId], map: "parent_agreement_network")
}

// ============================================================================
// THE INTELLIGENCE VAULT (YOUTUBE DATA SCRAPING & ANALYSIS)
// ============================================================================

model ExtractedIntelligence {
  id             String   @id @default(cuid())
  sourceChannel  String   @default("@AlaaCode")
  videoTitle     String
  videoUrl       String
  
  extractedTools String[] // Bijv: ["Framer Motion", "TailwindCSS", "Next.js 14"]
  coreConcept    String   @db.Text // De samenvatting van de techniek
  
  status         String   @default("ANALYZED") // ANALYZED, IMPLEMENTED
  createdAt      DateTime @default(now())
}

// ============================================================================
// COMPLIANCE & LEGAL ENFORCEMENT MODELS (ADDED POST-AUDIT)
// ============================================================================

model DecisionLedger {
  id                  String   @id @default(uuid())
  agentId             String
  actionProposed      String
  rationale           String   @db.Text
  
  // EU AI Act: Human-in-the-loop requirement
  requiresHumanApproval Boolean  @default(true)
  approvedByHumanId     String?
  approvalTimestamp     DateTime?
  status              String   @default("PENDING_REVIEW") // PENDING_REVIEW, APPROVED, REJECTED, EXECUTED
  
  createdAt           DateTime @default(now())
}

model AgentKnowledgeBase {
  id          String   @id @default(uuid())
  agentId     String
  knowledge   String?  @db.Text
  
  // GDPR: Data Minimization
  tenantId    String?  @default("default_tenant")
  containsPII Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================================
// CODE EVOLUTION ENGINE (CEE)
// ============================================================================

model CodeEvolutionGenome {
  id              String   @id @default(cuid())
  moduleName      String   // Bijv. "RIE Pricing Engine"
  
  // Enterprise Code Map
  healthScore     Float    @default(100.0) // 0-100% kwaliteit
  techDebtScore   Float    @default(0.0)
  
  identifiedIssues Json    // Dubbele logica, verouderde API's, kwetsbaarheden
  upgradePlan      Json    // Optimalisaties
  
  status          String   @default("MAPPED") // MAPPED, RESEARCHING, UPGRADING
  updatedAt       DateTime @updatedAt
  
  blueprints      ArchitectureBlueprint[]
}

model ArchitectureBlueprint {
  id              String   @id @default(cuid())
  genomeId        String
  genome          CodeEvolutionGenome @relation(fields: [genomeId], references: [id])
  
  // AI Architectuur
  currentFlow     String   @db.Text
  proposedFlow    String   @db.Text
  
  // Self-Improvement Loop
  isApproved      Boolean  @default(false)
  
  createdAt       DateTime @default(now())
}

model TreasuryVault {
  id              String   @id @default(uuid())
  tenantId        String?
  
  // Wft (Financial Law) Compliance: Explicitly internal platform credits
  balance         Float    @default(0.0)
  currencyType    String   @default("PLATFORM_CREDIT") // NEVER fiat (EUR/USD) to avoid shadow banking
  isFiat          Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================================================
// UNIVERSAL DATABASE INTELLIGENCE ENGINE (UDIE)
// ============================================================================

model DatabaseIntelligenceGenome {
  id              String   @id @default(cuid())
  targetDatabase  String   // Bijv. "Supabase_Main", "Redis_Cache"
  dbType          String   
  
  // Zelflerend (De "Medische Geschiedenis")
  identifiedAnomalies Json 
  appliedFixes        Json 
  
  status          String   @default("MONITORING") // MONITORING, SIMULATING, REPAIRING
  updatedAt       DateTime @updatedAt
  
  // Relatie naar actievoorstellen
  proposals       UdieActionProposal[]
}

model UdieActionProposal {
  id              String   @id @default(cuid())
  genomeId        String
  genome          DatabaseIntelligenceGenome @relation(fields: [genomeId], references: [id])
  
  // Analyse & Impact
  problemDetected String   @db.Text
  proposedFix     String   @db.Text
  expectedImpact  String   @db.Text
  
  // Database Guardian Layer
  riskScore       Int      // 1-10
  usersAffected   Int      @default(0)
  rollbackPlan    String   @db.Text
  isBackupVerified Boolean @default(false)
  
  // Autorisatie Status (Fase 1: Mens in de loop)
  authorization   String   @default("PENDING_HUMAN") // PENDING_HUMAN, AUTO_APPROVED, REJECTED, EXECUTED
  
  createdAt       DateTime @default(now())
}

// ============================================================================
// THE REVENUE INTELLIGENCE ENGINE (RIE)
// ============================================================================

model RevenueIntelligenceGenome {
  id              String   @id @default(cuid())
  modelName       String   @unique // Bijv. "Faceless Short-Form Automation"
  
  // Module 1 t/m 4: Identiteit, Business Analyse, Revenue Structuur, Markt Analyse
  identityMatrix  Json
  businessCore    Json
  revenueLogic    Json
  marketData      Json
  
  // Module 5 t/m 8: Concurrentie, Journey, Funnel, Traffic
  competitorIntel Json
  customerJourney Json
  funnelBlueprint Json
  trafficSources  Json
  
  // Module 9 t/m 11: Marketing, Sales, Psychologie
  marketingStrats Json
  salesStrats     Json
  psychology      Json
  
  // Module 12 t/m 15: Executie (AI & Automatisering)
  aiFeasibility   Json
  requiredAgents  String[]
  softwareStack   Json
  automationFlows Json
  
  // Module 16 t/m 20: Finance, Risico & Optimalisatie
  kpiBaselines    Json
  riskMatrix      Json
  exploitableEdges Json
  exitStrategy    Json
  learningLoop    Json
  
  status          String   @default("RESEARCHING") // RESEARCHING, VALIDATED, ACTIVE
  category        String   @default("UNCATEGORIZED") // SAAS_B2B, ECOMMERCE, CONTENT_MEDIA, SERVICES_LOCAL, AFFILIATE_LEADGEN
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  businessUnits   BusinessUnit[]
}

// ============================================================================
// THE BUSINESS MODEL FACTORY (BMF) & DEPLOYMENT SECURITY
// ============================================================================

model BusinessUnit {
  id              String   @id @default(cuid())
  genomeId        String
  genome          RevenueIntelligenceGenome @relation(fields: [genomeId], references: [id])
  
  domainName      String?
  frontendUrl     String?
  status          String   @default("BLUEPRINT") // BLUEPRINT, PROVISIONING, LIVE
  
  brandClusterId  String?
  brandCluster    BrandCluster? @relation(fields: [brandClusterId], references: [id])
  
  brandAssets     BrandAssetProfile?
  adEngines       AdScalingEngine[]
  
  logs            DeploymentLog[]
  financialReqs   FinancialActionRequest[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DeploymentLog {
  id              String   @id @default(cuid())
  unitId          String
  unit            BusinessUnit @relation(fields: [unitId], references: [id])
  
  action          String   // e.g., "BUY_DOMAIN", "SPIN_UP_SERVER"
  provider        String   // e.g., "VERCEL", "AWS", "NAMECHEAP"
  status          String   // e.g., "SUCCESS", "FAILED"
  details         String   @db.Text
  
  createdAt       DateTime @default(now())
}

model FinancialActionRequest {
  id              String   @id @default(cuid())
  unitId          String
  unit            BusinessUnit @relation(fields: [unitId], references: [id])
  
  actionType      String
  estimatedCost   Float
  currency        String   @default("EUR")
  provider        String
  
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED, EXECUTED
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BrandCluster {
  id              String   @id @default(cuid())
  name            String
  description     String?
  
  units           BusinessUnit[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AdScalingEngine {
  id              String   @id @default(cuid())
  unitId          String
  unit            BusinessUnit @relation(fields: [unitId], references: [id])
  
  channelName     String   // "META", "TIKTOK", "GOOGLE_SEARCH", "LINKEDIN", "PINTEREST"
  
  breakEvenCpa    Float
  targetRoas      Float
  currentDailyBudget Float @default(0.0)
  currentCpa      Float    @default(0.0)
  
  status          String   @default("LEARNING") // LEARNING, SCALING, CAPPED, KILLED
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BrandAssetProfile {
  id              String   @id @default(cuid())
  unitId          String   @unique
  unit            BusinessUnit @relation(fields: [unitId], references: [id])
  
  // AI Gegenereerde Data (via Sovereign Router)
  tiktokBio       String?  @db.VarChar(80)
  instagramBio    String?  @db.VarChar(150)
  linkedinAbout   String?  @db.Text
  twitterBio      String?  @db.VarChar(160)
  googleBusiness  String?  @db.Text
  
  brandColors     Json?    // Array met hex codes
  toneOfVoice     String?
  
  // Menselijke controle
  status          String   @default("AI_DRAFT") // AI_DRAFT, READY_TO_COPY
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
