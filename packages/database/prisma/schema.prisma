generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String                      @id @default(uuid())
  email                  String                      @unique
  passwordHash           String
  firstName              String
  lastName               String
  role                   String                      @default("USER")
  avatarUrl              String?
  isEmailVerified        Boolean                     @default(false)
  mfaEnabled             Boolean                     @default(false)
  mfaSecret              String?
  subscriptionTier       String                      @default("FREE")
  clearanceLevel         Int                         @default(1)
  experiencePoints       Int                         @default(0)
  profileType            String                      @default("PERSONAL")
  mollieCustomerId       String?
  mollieSubscriptionId   String?
  mollieAccessToken      String?
  mollieRefreshToken     String?
  mollieOrganizationId   String?
  subscriptionStatus     String                      @default("ACTIVE")
  onboardingCompleted    Boolean                     @default(false)
  openaiKey              String?
  lastLoginAt            DateTime?
  lastActiveAt           DateTime?                   @default(now())
  lastPingSentAt         DateTime?
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  deletedAt              DateTime?
  stripeCurrentPeriodEnd DateTime?
  stripeCustomerId       String?                     @unique
  stripePriceId          String?
  stripeSubscriptionId   String?                     @unique
  aiConciergeLogs        AIConciergeLog[]
  aiConversations        AIConversation[]
  aiMemories             AIMemory[]
  agentActions           AgentAction[]               @relation("UserActionReviews")
  agentDossiers          AgentDossier[]
  apiKeys                ApiKey[]
  auditLogs              AuditLog[]
  bankConnections        BankConnection[]
  budgets                Budget[]
  businessClients        BusinessClient[]
  creditorDossiers       CreditorDossier[]
  debts                  Debt[]
  emergencyRequests      EmergencyRequest[]
  goals                  Goal[]
  goalDossiers           GoalDossier[]
  healthLogs             HealthLog[]
  interceptionAlerts     InterceptionAlert[]         @relation("TargetedUser")
  justiceLedgers         JusticeLedger[]
  legalContacts          LegalContact[]
  lifeAreas              LifeArea[]
  marketingConversions   MarketingConversion[]
  notifications          Notification[]
  opportunityReports     OpportunityReport[]
  
  // Neo-Bank Relations
  godbrainAccount        GodbrainAccount?
  walletTransactions     WalletTransaction[]
  rebuildPrograms        RebuildProgram[]
  sessions               Session[]
  shopifyStores          ShopifyStore[]
  socialContacts         SocialContact[]
  socialMediaPosts       SocialMediaPost[]
  socialIntegrations     SocialPlatformIntegration[]
  tasks                  Task[]
  taxStrategies          TaxStrategy[]
  treasuryVaults         TreasuryVault[]
  syndicateCampaigns     SyndicateCampaign[]
  opportunities          Opportunity[]               @relation("AssignedOpportunities")
  lessonProgress         UserLessonProgress[]
  tradingBot             TradingBot?
  franchises             Franchise[]
  syndicatePosts         SyndicatePost[]
  syndicateComments      SyndicateComment[]
  syndicateLikes         SyndicateLike[]
  systemActivityLogs     SystemActivityLog[]

  @@index([email])
  @@index([role])
  @@index([subscriptionTier])
  @@index([createdAt])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  refreshToken String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LifeArea {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  score       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  goals       Goal[]
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model Goal {
  id           String    @id @default(uuid())
  userId       String
  lifeAreaId   String?
  title        String
  description  String?
  timeframe    String
  status       String    @default("NOT_STARTED")
  targetDate   DateTime?
  progress     Int       @default(0)
  parentGoalId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lifeArea     LifeArea? @relation(fields: [lifeAreaId], references: [id])
  parentGoal   Goal?     @relation("GoalHierarchy", fields: [parentGoalId], references: [id])
  subGoals     Goal[]    @relation("GoalHierarchy")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks        Task[]

  @@index([userId])
  @@index([userId, status])
  @@index([lifeAreaId])
  @@index([parentGoalId])
  @@index([timeframe])
  @@index([targetDate])
}

model Task {
  id                String    @id @default(uuid())
  userId            String
  goalId            String?
  title             String
  description       String?
  status            String    @default("PENDING")
  priority          String    @default("MEDIUM")
  dueDate           DateTime?
  completedAt       DateTime?
  assignedAgentType String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  goal              Goal?     @relation(fields: [goalId], references: [id])
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([userId, priority])
  @@index([goalId])
  @@index([dueDate])
  @@index([assignedAgentType])
}

model Budget {
  id            String           @id @default(uuid())
  userId        String
  month         DateTime
  totalIncome   Float
  totalExpenses Float
  savingsTarget Float
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories    BudgetCategory[]

  @@unique([userId, month])
  @@index([userId])
}

model BudgetCategory {
  id        String   @id @default(uuid())
  budgetId  String
  name      String
  planned   Float
  actual    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  budget    Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
}

model Debt {
  id             String        @id @default(uuid())
  userId         String
  creditorName   String
  originalAmount Float
  currentBalance Float
  interestRate   Float
  minimumPayment Float
  monthlyPayment Float
  dueDate        DateTime?
  status         String        @default("ACTIVE")
  notes          String?
  priority       Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments       DebtPayment[]

  @@index([userId])
  @@index([userId, status])
  @@index([status])
  @@index([priority])
}

model DebtPayment {
  id        String   @id @default(uuid())
  debtId    String
  amount    Float
  paidAt    DateTime
  notes     String?
  createdAt DateTime @default(now())
  debt      Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId])
  @@index([paidAt])
}

model RebuildProgram {
  id          String             @id @default(uuid())
  userId      String
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean            @default(true)
  progress    Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  milestones  ProgramMilestone[]
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActive])
}

model ProgramMilestone {
  id          String         @id @default(uuid())
  programId   String
  title       String
  description String?
  targetDate  DateTime?
  isCompleted Boolean        @default(false)
  completedAt DateTime?
  orderIndex  Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  program     RebuildProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
  @@index([programId, orderIndex])
}

model AIConversation {
  id        String      @id @default(uuid())
  userId    String
  agentType String
  title     String?
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AIMessage[]

  @@index([userId])
  @@index([userId, agentType])
  @@index([userId, isActive])
}

model AIMessage {
  id             String         @id @default(uuid())
  conversationId String
  role           String
  content        String
  tokenCount     Int?
  createdAt      DateTime       @default(now())
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

model AIMemory {
  id              String                 @id @default(uuid())
  content         String
  importance      Float                  @default(0.5)
  createdAt       DateTime               @default(now())
  expiresAt       DateTime?
  memoryType      String
  updatedAt       DateTime               @updatedAt
  userId          String
  agentType       String
  // vectorEmbedding Unsupported("vector")?
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, agentType])
  @@index([userId, memoryType])
  @@index([expiresAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  oldValue   String?
  newValue   String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model FeatureFlag {
  id          String   @id @default(uuid())
  name        String   @unique
  isEnabled   Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String
  name       String
  keyHash    String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
}

model HealthLog {
  id             String   @id @default(uuid())
  userId         String
  date           DateTime
  steps          Int?
  sleepScore     Int?
  weightKg       Float?
  waterMl        Int?
  workoutMinutes Int?
  workoutType    String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([userId, date])
}

model SocialContact {
  id                    String    @id @default(uuid())
  userId                String
  name                  String
  type                  String
  relationship          String?
  lastContactAt         DateTime?
  reminderFrequencyDays Int?
  notes                 String?
  phone                 String?
  email                 String?
  isImportant           Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@index([lastContactAt])
}

model BusinessClient {
  id            String            @id @default(uuid())
  userId        String
  name          String
  email         String?
  phone         String?
  company       String?
  status        String            @default("PROSPECT")
  notes         String?
  lastContactAt DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices      BusinessInvoice[]

  @@index([userId])
  @@index([userId, status])
}

model BusinessInvoice {
  id          String         @id @default(uuid())
  userId      String
  clientId    String
  invoiceNr   String
  description String?
  amount      Float
  status      String         @default("DRAFT")
  dueDate     DateTime?
  paidAt      DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  client      BusinessClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model OrionMemory {
  id              String                 @id @default(uuid())
  userId          String
  sessionId       String?
  memoryType      String
  trigger         String?
  content         String
  emotionalTone   String?
  intensity       Int                    @default(5)
  response        String?
  wasEffective    Boolean?
  learnWeight     Float                  @default(1.0)
  tags            String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  // vectorEmbedding Unsupported("vector")?

  @@index([userId])
  @@index([memoryType])
  @@index([emotionalTone])
  @@index([createdAt])
}

model RevenueSnapshot {
  id               String   @id @default(uuid())
  userId           String
  snapshotDate     DateTime
  period           String
  totalRevenue     Float    @default(0)
  totalExpenses    Float    @default(0)
  netProfit        Float    @default(0)
  missedRevenue    Float    @default(0)
  projectedRevenue Float    @default(0)
  actualVsBudget   Float    @default(0)
  vatReserve       Float    @default(0)
  safetyBuffer     Float    @default(0)
  source           String   @default("MANUAL")
  notes            String?
  cachedAt         DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([period])
  @@index([snapshotDate])
  @@index([userId, period])
}

model AnalyticsCache {
  id        String   @id @default(uuid())
  cacheKey  String   @unique
  data      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cacheKey])
  @@index([expiresAt])
}

model EnterpriseFolder {
  id          String               @id @default(uuid())
  name        String               @unique
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  documents   EnterpriseDocument[]
}

model EnterpriseDocument {
  id              String                 @id @default(uuid())
  folderId        String
  title           String
  owner           String
  status          String                 @default("DRAFT")
  category        String                 @default("GENERAL")
  priority        String                 @default("MEDIUM")
  source          String?
  content         String
  impact          String?
  nextStep        String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  // vectorEmbedding Unsupported("vector")?
  folder          EnterpriseFolder       @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([folderId])
  @@index([status])
  @@index([category])
  @@index([owner])
  @@index([createdAt])
}

model AgentAction {
  id               String    @id @default(uuid())
  agentType        String
  title            String
  description      String
  status           String    @default("PENDING")
  estimatedCost    Float     @default(0)
  estimatedRevenue Float     @default(0)
  transactionFees  Float     @default(0)
  netProfitImpact  Float     @default(0)
  riskLevel        String    @default("LOW")
  suggestedAt      DateTime  @default(now())
  reviewedAt       DateTime?
  reviewedBy       String?
  executedAt       DateTime?
  errorMessage     String?
  payload          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  reviewer         User?     @relation("UserActionReviews", fields: [reviewedBy], references: [id])

  @@index([agentType])
  @@index([status])
  @@index([reviewedBy])
}

model AgentBudget {
  id              String        @id @default(uuid())
  agentType       String        @unique
  totalAllocated  Float         @default(0)
  currentBalance  Float         @default(0)
  spentAmount     Float         @default(0)
  profitGenerated Float         @default(0)
  status          String        @default("ACTIVE")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  cards           VirtualCard[]

  @@index([agentType])
  @@index([status])
}

model VirtualCard {
  id            String      @id @default(uuid())
  budgetId      String
  cardProvider  String      @default("STRIPE_ISSUING")
  last4         String?
  spendingLimit Float       @default(50)
  isFrozen      Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  budget        AgentBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
}

model SocialPlatformIntegration {
  id           String           @id @default(uuid())
  userId       String
  platform     String
  accessToken  String?
  refreshToken String?
  accountId    String?
  status       String           @default("DISCONNECTED")
  scopes       String?
  expiresAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  campaigns    SocialCampaign[]
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([platform])
  @@index([status])
}

model SocialCampaign {
  id           String                    @id @default(uuid())
  platformId   String
  campaignName String
  campaignType String
  status       String                    @default("DRAFT")
  contentUrl   String?
  caption      String?
  budgetDaily  Float                     @default(0)
  totalSpend   Float                     @default(0)
  roas         Float                     @default(0)
  impressions  Int                       @default(0)
  clicks       Int                       @default(0)
  conversions  Int                       @default(0)
  publishedAt  DateTime?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  platform     SocialPlatformIntegration @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@index([platformId])
  @@index([status])
  @@index([campaignType])
}

model SystemHealthLog {
  id          String    @id @default(uuid())
  component   String
  status      String
  latencyMs   Int?
  errorLog    String?
  actionTaken String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([component])
  @@index([status])
  @@index([createdAt])
}

model BankConnection {
  id           String                 @id @default(uuid())
  userId       String
  provider     String
  accountId    String                 @unique
  accountName  String
  accessToken  String
  status       String                 @default("ACTIVE")
  lastSyncAt   DateTime               @default(now())
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]

  @@index([userId])
}

model FinancialTransaction {
  id               String         @id @default(uuid())
  bankConnectionId String
  amount           Float
  currency         String         @default("EUR")
  type             String
  category         String
  status           String         @default("COMPLETED")
  description      String?
  timestamp        DateTime       @default(now())
  bankConnection   BankConnection @relation(fields: [bankConnectionId], references: [id], onDelete: Cascade)

  @@index([bankConnectionId])
  @@index([type])
}

model AgentDossier {
  id        String   @id @default(uuid())
  agentType String
  action    String
  target    String?
  status    String   @default("SUCCESS")
  details   String?
  timestamp DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([agentType])
  @@index([userId])
  @@index([timestamp])
}

model ShopifyStore {
  id           String           @id @default(uuid())
  userId       String
  shopUrl      String
  accessToken  String
  status       String           @default("ACTIVE")
  totalRevenue Float            @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  products     ShopifyProduct[]
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, shopUrl])
  @@index([userId])
}

model ShopifyProduct {
  id          String       @id @default(uuid())
  storeId     String
  shopifyId   String       @unique
  title       String
  description String?
  price       Float
  margin      Float?
  status      String       @default("DRAFT")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  store       ShopifyStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([status])
}

model SocialMediaPost {
  id         String   @id @default(uuid())
  userId     String
  platform   String
  content    String
  mediaUrl   String?
  status     String   @default("SCHEDULED")
  publishAt  DateTime
  views      Int      @default(0)
  engagement Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platform])
  @@index([status])
}

model InterceptionAlert {
  id           String   @id @default(uuid())
  targetUserId String
  triggerType  String
  metrics      String
  status       String   @default("UNREAD")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  targetUser   User     @relation("TargetedUser", fields: [targetUserId], references: [id])

  @@index([targetUserId])
  @@index([status])
  @@index([triggerType])
}

// ==========================================
// NEO-BANK & TRADING INFRASTRUCTURE
// ==========================================

model GodbrainAccount {
  id              String   @id @default(uuid())
  userId          String   @unique
  iban            String   @unique
  swift           String
  accountHolder   String   // Name of the business/user
  status          String   @default("ACTIVE") // "ACTIVE", "FROZEN", "PENDING_KYC"
  currency        String   @default("EUR")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WalletTransaction {
  id              String   @id @default(uuid())
  userId          String
  vaultId         String?  // The specific vault this transaction affected
  amount          Float
  type            String   // "DEPOSIT", "WITHDRAWAL", "TRADE_EXECUTION", "TAX_RESERVE"
  executedBy      String   // "USER", "SWARM_EXECUTOR", "SYSTEM"
  status          String   @default("COMPLETED")
  description     String?
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vault           TreasuryVault? @relation(fields: [vaultId], references: [id])

  @@index([userId])
  @@index([vaultId])
  @@index([type])
}

model TreasuryVault {
  id              String   @id @default(uuid())
  userId          String
  vaultType       String   @default("OPERATIONS") // "OPERATIONS", "TAX", "SYNDICATE_CAPITAL", "TRADING"
  balance         Float    @default(0.0)
  reservedRiskCap Float    @default(0.0)
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    WalletTransaction[]

  @@index([userId])
  @@index([vaultType])
}

model TaxStrategy {
  id              String   @id @default(uuid())
  userId          String
  potName         String
  allocatedAmount Float    @default(0.0)
  taxAdvantage    Float    @default(0.0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CreditorDossier {
  id               String   @id @default(uuid())
  userId           String
  creditorName     String
  dossierNumber    String
  encryptedData    String
  status           String   @default("SCANNING")
  monthlyRepayment Float    @default(0.0)
  createdAt        DateTime @default(now())
