datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------------------------
// Base Core Models for the Kernel / Security / Governance Layer
// ---------------------------------------------------------------------------

model Tenant {
  id        String   @id @default(uuid())
  name      String
  plan      String   @default("FREE")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaties naar abstracte data
  users     User[]
}

model User {
  id        String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  role         String   @default("VIEWER") // Verwijst naar HumanRole enum
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions  Session[]
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  refreshToken String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
