generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String           @id @default(uuid())
  email                String           @unique
  passwordHash         String
  firstName            String
  lastName             String
  role                 String           @default("USER")
  avatarUrl            String?
  isEmailVerified      Boolean          @default(false)
  mfaEnabled           Boolean          @default(false)
  mfaSecret            String?
  subscriptionTier     String           @default("FREE")
  clearanceLevel       Int              @default(1)
  experiencePoints     Int              @default(0)
  profileType          String           @default("PERSONAL")
  mollieCustomerId     String?
  mollieSubscriptionId String?
  subscriptionStatus   String           @default("ACTIVE")
  onboardingCompleted  Boolean          @default(false)
  openaiKey            String?
  lastLoginAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  aiConversations      AIConversation[]
  aiMemories           AIMemory[]
  apiKeys              ApiKey[]
  auditLogs            AuditLog[]
  budgets              Budget[]
  businessClients      BusinessClient[]
  debts                Debt[]
  goals                Goal[]
  healthLogs           HealthLog[]
  lifeAreas            LifeArea[]
  notifications        Notification[]
  rebuildPrograms      RebuildProgram[]
  sessions             Session[]
  socialContacts       SocialContact[]
  tasks                Task[]

  @@index([email])
  @@index([role])
  @@index([subscriptionTier])
  @@index([createdAt])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  refreshToken String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LifeArea {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  score       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  goals       Goal[]
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model Goal {
  id           String    @id @default(uuid())
  userId       String
  lifeAreaId   String?
  title        String
  description  String?
  timeframe    String
  status       String    @default("NOT_STARTED")
  targetDate   DateTime?
  progress     Int       @default(0)
  parentGoalId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lifeArea     LifeArea? @relation(fields: [lifeAreaId], references: [id])
  parentGoal   Goal?     @relation("GoalHierarchy", fields: [parentGoalId], references: [id])
  subGoals     Goal[]    @relation("GoalHierarchy")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks        Task[]

  @@index([userId])
  @@index([userId, status])
  @@index([lifeAreaId])
  @@index([parentGoalId])
  @@index([timeframe])
  @@index([targetDate])
}

model Task {
  id                String    @id @default(uuid())
  userId            String
  goalId            String?
  title             String
  description       String?
  status            String    @default("PENDING")
  priority          String    @default("MEDIUM")
  dueDate           DateTime?
  completedAt       DateTime?
  assignedAgentType String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  goal              Goal?     @relation(fields: [goalId], references: [id])
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([userId, priority])
  @@index([goalId])
  @@index([dueDate])
  @@index([assignedAgentType])
}

model Budget {
  id            String           @id @default(uuid())
  userId        String
  month         DateTime
  totalIncome   Float
  totalExpenses Float
  savingsTarget Float
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories    BudgetCategory[]

  @@unique([userId, month])
  @@index([userId])
}

model BudgetCategory {
  id        String   @id @default(uuid())
  budgetId  String
  name      String
  planned   Float
  actual    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  budget    Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
}

model Debt {
  id             String        @id @default(uuid())
  userId         String
  creditorName   String
  originalAmount Float
  currentBalance Float
  interestRate   Float
  minimumPayment Float
  monthlyPayment Float
  dueDate        DateTime?
  status         String        @default("ACTIVE")
  notes          String?
  priority       Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments       DebtPayment[]

  @@index([userId])
  @@index([userId, status])
  @@index([status])
  @@index([priority])
}

model DebtPayment {
  id        String   @id @default(uuid())
  debtId    String
  amount    Float
  paidAt    DateTime
  notes     String?
  createdAt DateTime @default(now())
  debt      Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId])
  @@index([paidAt])
}

model RebuildProgram {
  id          String             @id @default(uuid())
  userId      String
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean            @default(true)
  progress    Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  milestones  ProgramMilestone[]
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActive])
}

model ProgramMilestone {
  id          String         @id @default(uuid())
  programId   String
  title       String
  description String?
  targetDate  DateTime?
  isCompleted Boolean        @default(false)
  completedAt DateTime?
  orderIndex  Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  program     RebuildProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
  @@index([programId, orderIndex])
}

model AIConversation {
  id        String      @id @default(uuid())
  userId    String
  agentType String
  title     String?
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AIMessage[]

  @@index([userId])
  @@index([userId, agentType])
  @@index([userId, isActive])
}

model AIMessage {
  id             String         @id @default(uuid())
  conversationId String
  role           String
  content        String
  tokenCount     Int?
  createdAt      DateTime       @default(now())
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

model AIMemory {
  id         String    @id @default(uuid())
  userId     String
  agentType  String
  memoryType String
  content    String
  embedding  String?
  importance Float     @default(0.5)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, agentType])
  @@index([userId, memoryType])
  @@index([expiresAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  oldValue   String?
  newValue   String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model FeatureFlag {
  id          String   @id @default(uuid())
  name        String   @unique
  isEnabled   Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String
  name       String
  keyHash    String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
}

model HealthLog {
  id             String   @id @default(uuid())
  userId         String
  date           DateTime
  steps          Int?
  sleepScore     Int?
  weightKg       Float?
  waterMl        Int?
  workoutMinutes Int?
  workoutType    String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([userId, date])
}

model SocialContact {
  id                    String    @id @default(uuid())
  userId                String
  name                  String
  type                  String
  relationship          String?
  lastContactAt         DateTime?
  reminderFrequencyDays Int?
  notes                 String?
  phone                 String?
  email                 String?
  isImportant           Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@index([lastContactAt])
}

model BusinessClient {
  id            String            @id @default(uuid())
  userId        String
  name          String
  email         String?
  phone         String?
  company       String?
  status        String            @default("PROSPECT")
  notes         String?
  lastContactAt DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices      BusinessInvoice[]

  @@index([userId])
  @@index([userId, status])
}

model BusinessInvoice {
  id          String         @id @default(uuid())
  userId      String
  clientId    String
  invoiceNr   String
  description String?
  amount      Float
  status      String         @default("DRAFT")
  dueDate     DateTime?
  paidAt      DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  client      BusinessClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
}

model EnterpriseFolder {
  id          String               @id @default(uuid())
  name        String               @unique
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  documents   EnterpriseDocument[]
}

model EnterpriseDocument {
  id        String           @id @default(uuid())
  folderId  String
  title     String
  owner     String
  status    String           @default("DRAFT")
  category  String           @default("GENERAL")
  priority  String           @default("MEDIUM")
  source    String?
  content   String
  impact    String?
  nextStep  String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  folder    EnterpriseFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([folderId])
  @@index([status])
  @@index([category])
  @@index([owner])
  @@index([createdAt])
}
