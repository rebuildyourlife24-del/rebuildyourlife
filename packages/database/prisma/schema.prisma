datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  CANCELLED
  EXPIRED
  SUSPENDED
}

enum SubscriptionTier {
  FREE
  PREMIUM
  ENTERPRISE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ---------------------------------------------------------------------------
// Base Core Models for the Kernel / Security / Governance Layer
// ---------------------------------------------------------------------------

model Tenant {
  id        String   @id @default(uuid())
  name      String
  plan      String   @default("FREE")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaties naar abstracte data
  users     User[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  firstName    String?
  lastName     String?
  passwordHash String?
  role         String   @default("VIEWER") // Verwijst naar HumanRole enum
  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  subscriptionTier   SubscriptionTier   @default(FREE)
  tenantId           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions      Session[]
  orionMemories OrionMemory[]
  aiMemories    AIMemory[]
  auditLogs     AuditLog[]
  agentActions  AgentAction[]
  budgets       Budget[]
  debts         Debt[]
  tasks         Task[]
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  refreshToken String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Agentic & Orion Memory Models
// ---------------------------------------------------------------------------

model OrionMemory {
  id            String   @id @default(uuid())
  userId        String
  memoryType    String
  trigger       String   @db.Text
  content       String   @db.Text
  emotionalTone String
  intensity     Int
  learnWeight   Float
  tags          String?
  response      String?  @db.Text
  wasEffective  Boolean?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AIMemory {
  id            String   @id @default(uuid())
  userId        String
  agentType     String
  memoryType    String
  content       String   @db.Text
  importance    Int
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id            String   @id @default(uuid())
  userId        String
  action        String   @db.Text
  entityType    String
  newValue      String?  @db.Text
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgentAction {
  id               String   @id @default(uuid())
  userId           String
  agentType        String
  title            String
  description      String   @db.Text
  status           String   // PENDING, APPROVED, REJECTED
  estimatedCost    Float
  estimatedRevenue Float
  transactionFees  Float
  netProfitImpact  Float
  riskLevel        String   // LOW, MEDIUM, HIGH, CRITICAL
  suggestedAt      DateTime @default(now())
  reviewedAt       DateTime?

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Financial & Analytics Models
// ---------------------------------------------------------------------------

model Budget {
  id            String   @id @default(uuid())
  userId        String
  month         DateTime
  totalIncome   Float    @default(0)
  totalExpenses Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Debt {
  id             String   @id @default(uuid())
  userId         String
  creditorName   String
  originalAmount Float    @default(0)
  currentBalance Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments       DebtPayment[]
}

model DebtPayment {
  id        String   @id @default(uuid())
  debtId    String
  amount    Float
  paidAt    DateTime @default(now())

  debt      Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
}

model AnalyticsCache {
  id        String   @id @default(uuid())
  cacheKey  String   @unique
  data      String   @db.Text
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Task {
  id          String     @id @default(uuid())
  userId      String
  title       String
  description String?    @db.Text
  status      TaskStatus @default(PENDING)
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}
