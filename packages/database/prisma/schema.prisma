// ============================================================================
// RebuildYourLife AI Coworker OS — Prisma Schema (SQLite Version)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// Models (Enums replaced with Strings for SQLite compatibility)
// ============================================================================

model User {
  id                  String           @id @default(uuid())
  email               String           @unique
  passwordHash        String
  firstName           String
  lastName            String
  role                String           @default("USER") // ADMIN, USER, PREMIUM
  avatarUrl           String?
  isEmailVerified     Boolean          @default(false)
  mfaEnabled          Boolean          @default(false)
  mfaSecret           String?
  subscriptionTier    String           @default("FREE") // FREE, BASIC, PREMIUM, ENTERPRISE
  clearanceLevel      Int              @default(1) // Operator Rank (1-10)
  experiencePoints    Int              @default(0) // XP for gamification
  profileType         String           @default("PERSONAL") // PERSONAL, BUSINESS, COMBINED
  mollieCustomerId    String?
  mollieSubscriptionId String?
  subscriptionStatus  String           @default("ACTIVE") // ACTIVE, CANCELED, PAST_DUE
  onboardingCompleted Boolean          @default(false)
  openaiKey           String?
  lastLoginAt         DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  sessions         Session[]
  lifeAreas        LifeArea[]
  goals            Goal[]
  tasks            Task[]
  budgets          Budget[]
  debts            Debt[]
  rebuildPrograms  RebuildProgram[]
  aiConversations  AIConversation[]
  aiMemories       AIMemory[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  apiKeys          ApiKey[]
  healthLogs       HealthLog[]
  socialContacts   SocialContact[]
  businessClients  BusinessClient[]

  @@index([email])
  @@index([role])
  @@index([subscriptionTier])
  @@index([createdAt])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  refreshToken String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LifeArea {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  score       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  goals Goal[]

  @@unique([userId, name])
  @@index([userId])
}

model Goal {
  id           String        @id @default(uuid())
  userId       String
  lifeAreaId   String?
  title        String
  description  String?
  timeframe    String        // YEAR, QUARTER, MONTH, WEEK, DAY
  status       String        @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED, ABANDONED
  targetDate   DateTime?
  progress     Int           @default(0)
  parentGoalId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lifeArea   LifeArea? @relation(fields: [lifeAreaId], references: [id], onDelete: SetNull)
  parentGoal Goal?     @relation("GoalHierarchy", fields: [parentGoalId], references: [id], onDelete: SetNull)
  subGoals   Goal[]    @relation("GoalHierarchy")
  tasks      Task[]

  @@index([userId])
  @@index([userId, status])
  @@index([lifeAreaId])
  @@index([parentGoalId])
  @@index([timeframe])
  @@index([targetDate])
}

model Task {
  id               String      @id @default(uuid())
  userId           String
  goalId           String?
  title            String
  description      String?
  status           String      @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  priority         String      @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  dueDate          DateTime?
  completedAt      DateTime?
  assignedAgentType String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Goal? @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, status])
  @@index([userId, priority])
  @@index([goalId])
  @@index([dueDate])
  @@index([assignedAgentType])
}

model Budget {
  id            String   @id @default(uuid())
  userId        String
  month         DateTime
  totalIncome   Float
  totalExpenses Float
  savingsTarget Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories BudgetCategory[]

  @@unique([userId, month])
  @@index([userId])
}

model BudgetCategory {
  id        String   @id @default(uuid())
  budgetId  String
  name      String
  planned   Float
  actual    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
}

model Debt {
  id             String     @id @default(uuid())
  userId         String
  creditorName   String
  originalAmount Float
  currentBalance Float
  interestRate   Float
  minimumPayment Float
  monthlyPayment Float
  dueDate        DateTime?
  status         String     @default("ACTIVE") // ACTIVE, NEGOTIATING, PAYMENT_PLAN, SETTLED, DISPUTED
  notes          String?
  priority       Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments DebtPayment[]

  @@index([userId])
  @@index([userId, status])
  @@index([status])
  @@index([priority])
}

model DebtPayment {
  id        String   @id @default(uuid())
  debtId    String
  amount    Float
  paidAt    DateTime
  notes     String?
  createdAt DateTime @default(now())

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId])
  @@index([paidAt])
}

model RebuildProgram {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean  @default(true)
  progress    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones ProgramMilestone[]

  @@index([userId])
  @@index([userId, isActive])
}

model ProgramMilestone {
  id          String    @id @default(uuid())
  programId   String
  title       String
  description String?
  targetDate  DateTime?
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  orderIndex  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  program RebuildProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
  @@index([programId, orderIndex])
}

model AIConversation {
  id        String    @id @default(uuid())
  userId    String
  agentType String
  title     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIMessage[]

  @@index([userId])
  @@index([userId, agentType])
  @@index([userId, isActive])
}

model AIMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String
  content        String
  tokenCount     Int?
  createdAt      DateTime @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

model AIMemory {
  id         String     @id @default(uuid())
  userId     String
  agentType  String
  memoryType String
  content    String
  embedding  String?    // Storing vector as JSON string for SQLite
  importance Float      @default(0.5)
  expiresAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, agentType])
  @@index([userId, memoryType])
  @@index([expiresAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  oldValue   String? // Store JSON as string
  newValue   String? // Store JSON as string
  ipAddress  String?
  createdAt  DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model FeatureFlag {
  id          String   @id @default(uuid())
  name        String   @unique
  isEnabled   Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model ApiKey {
  id        String   @id @default(uuid())
  userId    String
  name      String
  keyHash   String   @unique
  lastUsedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
}

// ============================================================================
// Phase 5: Complete Life OS Models
// ============================================================================

model HealthLog {
  id              String   @id @default(uuid())
  userId          String
  date            DateTime
  steps           Int?
  sleepScore      Int?     // 1-10
  weightKg        Float?
  waterMl         Int?
  workoutMinutes  Int?
  workoutType     String?  // STRENGTH, CARDIO, YOGA, etc.
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([userId, date])
}

model SocialContact {
  id                    String   @id @default(uuid())
  userId                String
  name                  String
  type                  String   // FAMILY, FRIEND, PARTNER, COLLEAGUE
  relationship          String?  // e.g. "Broer", "Beste vriend"
  lastContactAt         DateTime?
  reminderFrequencyDays Int?     // How often to remind user to contact
  notes                 String?
  phone                 String?
  email                 String?
  isImportant           Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@index([lastContactAt])
}

model BusinessClient {
  id            String            @id @default(uuid())
  userId        String
  name          String
  email         String?
  phone         String?
  company       String?
  status        String            @default("PROSPECT") // PROSPECT, ACTIVE, INACTIVE
  notes         String?
  lastContactAt DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices BusinessInvoice[]

  @@index([userId])
  @@index([userId, status])
}

model BusinessInvoice {
  id          String   @id @default(uuid())
  userId      String
  clientId    String
  invoiceNr   String
  description String?
  amount      Float
  status      String   @default("DRAFT") // DRAFT, SENT, PAID, OVERDUE
  dueDate     DateTime?
  paidAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client BusinessClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
}

// ============================================================================
// Phase 6: Enterprise OS (God-Mode Knowledge Vault)
// ============================================================================

model EnterpriseFolder {
  id          String   @id @default(uuid())
  name        String   // /CEO, /Strategy, /Marketing, etc.
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents   EnterpriseDocument[]

  @@unique([name])
}

model EnterpriseDocument {
  id          String   @id @default(uuid())
  folderId    String
  title       String
  owner       String   // e.g. "CEO Agent", "Data Intelligence Agent", "Henk"
  status      String   @default("DRAFT") // DRAFT, REVIEW, APPROVED, ARCHIVED
  category    String   @default("GENERAL") // RAW, PROCESSED, FINAL, REPORT, DECISION
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  source      String?  // Where did this data come from?
  content     String   // The actual document content/JSON
  impact      String?
  nextStep    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  folder      EnterpriseFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([folderId])
  @@index([status])
  @@index([category])
  @@index([owner])
  @@index([createdAt])
}
