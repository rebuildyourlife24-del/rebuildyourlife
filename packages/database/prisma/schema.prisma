// PROJECT SOVEREIGN: PILLAR 3 & 4
// Helpdesk & Native Ad Manager
// =======================================================

model HelpdeskTicket {
  id          String   @id @default(uuid())
  userId      String
  customerName String
  customerEmail String
  subject     String
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  assignedTo  String?  // 'ORION', 'HERMES', or UUID of a User
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  messages    TicketMessage[]
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model TicketMessage {
  id        String   @id @default(uuid())
  ticketId  String
  sender    String   // 'CUSTOMER', 'AGENT', 'AI'
  body      String   @db.Text
  createdAt DateTime @default(now())
  ticket    HelpdeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model AdSet {
  id           String   @id @default(uuid())
  campaignId   String
  name         String
  targetAudience String?
  dailyBudget  Float    @default(0)
  status       String   @default("ACTIVE") // ACTIVE, PAUSED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  campaign     SocialCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creatives    AdCreative[]

  @@index([campaignId])
}

model AdCreative {
  id           String   @id @default(uuid())
  adSetId      String
  headline     String
  body         String   @db.Text
  mediaUrl     String?
  status       String   @default("ACTIVE")
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  spend        Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  adSet        AdSet    @relation(fields: [adSetId], references: [id], onDelete: Cascade)

  @@index([adSetId])
}


model AffiliateProfile {
  id               String          @id @default(uuid())
  userId           String          @unique
  affiliateCode    String          @unique
  commissionRate   Float           @default(30.0) // Fallback for standard products
  totalEarned      Float           @default(0)
  pendingBalance   Float           @default(0)
  status           String          @default("ACTIVE")
  
  // MLM / Multi-Tier Network
  parentAffiliateId String?
  parentAffiliate   AffiliateProfile?  @relation("AffiliateNetwork", fields: [parentAffiliateId], references: [id], onDelete: SetNull)
  subAffiliates     AffiliateProfile[] @relation("AffiliateNetwork")

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  clicks           AffiliateClick[]
  sales            AffiliateSale[] @relation("DirectSales")
  tier2Sales       AffiliateSale[] @relation("Tier2Sales")

  @@index([userId])
  @@index([affiliateCode])
  @@index([parentAffiliateId])
}

model AffiliateClick {
  id                 String           @id @default(uuid())
  affiliateProfileId String
  ipAddress          String?
  userAgent          String?
  referrer           String?
  clickedAt          DateTime         @default(now())
  userId             String?
  affiliateProfile   AffiliateProfile @relation(fields: [affiliateProfileId], references: [id], onDelete: Cascade)
  user               User?            @relation(fields: [userId], references: [id])

  @@index([affiliateProfileId])
  @@index([clickedAt])
}

model AffiliateSale {
  id                      String           @id @default(uuid())
  affiliateProfileId      String
  tier2AffiliateProfileId String?
  purchaserUserId         String?
  molliePaymentId         String
  amount                  Float
  
  // Fixed commissions
  commission              Float            // Direct seller (Tier 1)
  tier2Commission         Float            @default(0) // Parent seller (Tier 2)
  
  status                  String           @default("PENDING")
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  
  affiliateProfile        AffiliateProfile @relation("DirectSales", fields: [affiliateProfileId], references: [id], onDelete: Cascade)
  tier2AffiliateProfile   AffiliateProfile? @relation("Tier2Sales", fields: [tier2AffiliateProfileId], references: [id], onDelete: SetNull)
  purchaser               User?            @relation(fields: [purchaserUserId], references: [id])

  @@index([affiliateProfileId])
  @@index([tier2AffiliateProfileId])
  @@index([status])
  @@index([molliePaymentId])
}

