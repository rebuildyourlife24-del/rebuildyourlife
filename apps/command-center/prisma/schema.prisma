generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  output          = "../node_modules/.prisma/client"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

// ─────────────────────────────────────────────────────────────────────────────
// CANONICAL SHARED SCHEMA — mirrors packages/database/prisma/schema.prisma
// ALL apps use the SAME Supabase project: maruupmdslovtfcoxdlu (eu-west-1)
// Login: hsemler50@gmail.com / Megan123!
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                   String   @id @default(uuid())
  email                String   @unique
  passwordHash         String
  firstName            String
  lastName             String
  role                 String   @default("USER")
  avatarUrl            String?
  isEmailVerified      Boolean  @default(false)
  mfaEnabled           Boolean  @default(false)
  mfaSecret            String?
  subscriptionTier     String   @default("FREE")
  clearanceLevel       Int      @default(1)
  experiencePoints     Int      @default(0)
  profileType          String   @default("PERSONAL")
  mollieCustomerId     String?
  mollieSubscriptionId String?
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?
  subscriptionStatus   String   @default("ACTIVE")
  onboardingCompleted  Boolean  @default(false)
  openaiKey            String?
  lastLoginAt          DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  sessions             Session[]
  aiConversations      AIConversation[]
  aiMemories           AIMemory[]
  orionMemories        OrionMemory[]
  auditLogs            AuditLog[]
  goals                Goal[]
  tasks                Task[]
  debts                Debt[]
  budgets              Budget[]
  notifications        Notification[]
  agentActions         AgentAction[]  @relation("UserActionReviews")
  apiKeys              ApiKey[]
  healthLogs           HealthLog[]
  lifeAreas            LifeArea[]
  rebuildPrograms      RebuildProgram[]
  socialContacts       SocialContact[]
  socialIntegrations   SocialPlatformIntegration[]
  bankConnections      BankConnection[]
  businessClients      BusinessClient[]
  agentDossiers        AgentDossier[]
  shopifyStores        ShopifyStore[]
  socialMediaPosts     SocialMediaPost[]
  interceptionAlerts   InterceptionAlert[] @relation("TargetedUser")
  treasuryVaults       TreasuryVault[]
  taxStrategies        TaxStrategy[]
  creditorDossiers     CreditorDossier[]
  legalContacts        LegalContact[]
  justiceLedgers       JusticeLedger[]
  goalDossiers         GoalDossier[]
  emergencyRequests    EmergencyRequest[]
  opportunityReports   OpportunityReport[]
  marketingConversions MarketingConversion[]
  aiConciergeLogs      AIConciergeLog[]
  revenueSnapshots     RevenueSnapshot[]

  @@index([email])
  @@index([role])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  refreshToken String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Goal {
  id           String    @id @default(uuid())
  userId       String
  lifeAreaId   String?
  title        String
  description  String?
  timeframe    String
  status       String    @default("NOT_STARTED")
  targetDate   DateTime?
  progress     Int       @default(0)
  parentGoalId String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lifeArea     LifeArea? @relation(fields: [lifeAreaId], references: [id])
  parentGoal   Goal?     @relation("GoalHierarchy", fields: [parentGoalId], references: [id])
  subGoals     Goal[]    @relation("GoalHierarchy")
  tasks        Task[]

  @@index([userId])
}

model Task {
  id                String    @id @default(uuid())
  userId            String
  goalId            String?
  title             String
  description       String?
  status            String    @default("PENDING")
  priority          String    @default("MEDIUM")
  dueDate           DateTime?
  completedAt       DateTime?
  assignedAgentType String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal              Goal?     @relation(fields: [goalId], references: [id])

  @@index([userId])
}

model Budget {
  id            String           @id @default(uuid())
  userId        String
  month         DateTime
  totalIncome   Float
  totalExpenses Float
  savingsTarget Float
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  categories    BudgetCategory[]

  @@unique([userId, month])
  @@index([userId])
}

model BudgetCategory {
  id        String   @id @default(uuid())
  budgetId  String
  name      String
  planned   Float
  actual    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  budget    Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
}

model Debt {
  id             String        @id @default(uuid())
  userId         String
  creditorName   String
  originalAmount Float
  currentBalance Float
  interestRate   Float
  minimumPayment Float
  monthlyPayment Float
  dueDate        DateTime?
  status         String        @default("ACTIVE")
  notes          String?
  priority       Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments       DebtPayment[]

  @@index([userId])
}

model DebtPayment {
  id        String   @id @default(uuid())
  debtId    String
  amount    Float
  paidAt    DateTime
  notes     String?
  createdAt DateTime @default(now())
  debt      Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId])
}

model LifeArea {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  score       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goals       Goal[]

  @@unique([userId, name])
  @@index([userId])
}

model RebuildProgram {
  id          String             @id @default(uuid())
  userId      String
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean            @default(true)
  progress    Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones  ProgramMilestone[]

  @@index([userId])
}

model ProgramMilestone {
  id          String         @id @default(uuid())
  programId   String
  title       String
  description String?
  targetDate  DateTime?
  isCompleted Boolean        @default(false)
  completedAt DateTime?
  orderIndex  Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  program     RebuildProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
}

model AIConversation {
  id        String      @id @default(uuid())
  userId    String
  agentType String
  title     String?
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AIMessage[]

  @@index([userId])
}

model AIMessage {
  id             String         @id @default(uuid())
  conversationId String
  role           String
  content        String
  tokenCount     Int?
  createdAt      DateTime       @default(now())
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model AIMemory {
  id              String    @id @default(uuid())
  userId          String
  agentType       String
  memoryType      String
  content         String
  vectorEmbedding Unsupported("vector(1536)")?
  importance      Float     @default(0.5)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OrionMemory {
  id              String   @id @default(uuid())
  userId          String
  sessionId       String?
  memoryType      String
  trigger         String?
  content         String
  vectorEmbedding Unsupported("vector(1536)")?
  emotionalTone   String?
  intensity       Int      @default(5)
  response        String?
  wasEffective    Boolean?
  learnWeight     Float    @default(1.0)
  tags            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([memoryType])
  @@index([emotionalTone])
}

model RevenueSnapshot {
  id               String   @id @default(uuid())
  userId           String
  snapshotDate     DateTime
  period           String
  totalRevenue     Float    @default(0)
  totalExpenses    Float    @default(0)
  netProfit        Float    @default(0)
  missedRevenue    Float    @default(0)
  projectedRevenue Float    @default(0)
  actualVsBudget   Float    @default(0)
  vatReserve       Float    @default(0)
  safetyBuffer     Float    @default(0)
  source           String   @default("MANUAL")
  notes            String?
  cachedAt         DateTime @default(now())
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([period])
}

model AnalyticsCache {
  id        String   @id @default(uuid())
  cacheKey  String   @unique
  data      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cacheKey])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String?
  oldValue   String?
  newValue   String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
}

model FeatureFlag {
  id          String   @id @default(uuid())
  name        String   @unique
  isEnabled   Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String
  name       String
  keyHash    String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model HealthLog {
  id             String   @id @default(uuid())
  userId         String
  date           DateTime
  steps          Int?
  sleepScore     Int?
  weightKg       Float?
  waterMl        Int?
  workoutMinutes Int?
  workoutType    String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model SocialContact {
  id                    String    @id @default(uuid())
  userId                String
  name                  String
  type                  String
  relationship          String?
  lastContactAt         DateTime?
  reminderFrequencyDays Int?
  notes                 String?
  phone                 String?
  email                 String?
  isImportant           Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BusinessClient {
  id            String            @id @default(uuid())
  userId        String
  name          String
  email         String?
  phone         String?
  company       String?
  status        String            @default("PROSPECT")
  notes         String?
  lastContactAt DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices      BusinessInvoice[]

  @@index([userId])
}

model BusinessInvoice {
  id          String         @id @default(uuid())
  userId      String
  clientId    String
  invoiceNr   String
  description String?
  amount      Float
  status      String         @default("DRAFT")
  dueDate     DateTime?
  paidAt      DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  client      BusinessClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
}

model EnterpriseFolder {
  id          String               @id @default(uuid())
  name        String               @unique
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  documents   EnterpriseDocument[]
}

model EnterpriseDocument {
  id              String           @id @default(uuid())
  folderId        String
  title           String
  owner           String
  status          String           @default("DRAFT")
  category        String           @default("GENERAL")
  priority        String           @default("MEDIUM")
  source          String?
  content         String
  vectorEmbedding Unsupported("vector(1536)")?
  impact          String?
  nextStep        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  folder          EnterpriseFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([folderId])
}

model AgentAction {
  id               String    @id @default(uuid())
  agentType        String
  title            String
  description      String
  status           String    @default("PENDING")
  estimatedCost    Float     @default(0)
  estimatedRevenue Float     @default(0)
  transactionFees  Float     @default(0)
  netProfitImpact  Float     @default(0)
  riskLevel        String    @default("LOW")
  suggestedAt      DateTime  @default(now())
  reviewedAt       DateTime?
  reviewedBy       String?
  executedAt       DateTime?
  errorMessage     String?
  payload          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  reviewer         User?     @relation("UserActionReviews", fields: [reviewedBy], references: [id])

  @@index([agentType])
  @@index([status])
}

model AgentBudget {
  id              String        @id @default(uuid())
  agentType       String        @unique
  totalAllocated  Float         @default(0)
  currentBalance  Float         @default(0)
  spentAmount     Float         @default(0)
  profitGenerated Float         @default(0)
  status          String        @default("ACTIVE")
  cards           VirtualCard[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model VirtualCard {
  id            String      @id @default(uuid())
  budgetId      String
  cardProvider  String      @default("STRIPE_ISSUING")
  last4         String?
  spendingLimit Float       @default(50)
  isFrozen      Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  budget        AgentBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
}

model SocialPlatformIntegration {
  id           String           @id @default(uuid())
  userId       String
  platform     String
  accessToken  String?
  refreshToken String?
  accountId    String?
  status       String           @default("DISCONNECTED")
  scopes       String?
  expiresAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns    SocialCampaign[]

  @@unique([userId, platform])
}

model SocialCampaign {
  id           String                    @id @default(uuid())
  platformId   String
  campaignName String
  campaignType String
  status       String                    @default("DRAFT")
  contentUrl   String?
  caption      String?
  budgetDaily  Float                     @default(0)
  totalSpend   Float                     @default(0)
  roas         Float                     @default(0)
  impressions  Int                       @default(0)
  clicks       Int                       @default(0)
  conversions  Int                       @default(0)
  publishedAt  DateTime?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  platform     SocialPlatformIntegration @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@index([platformId])
}

model SystemHealthLog {
  id          String    @id @default(uuid())
  component   String
  status      String
  latencyMs   Int?
  errorLog    String?
  actionTaken String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([component])
}

model BankConnection {
  id           String                 @id @default(uuid())
  userId       String
  provider     String
  accountId    String                 @unique
  accountName  String
  accessToken  String
  status       String                 @default("ACTIVE")
  lastSyncAt   DateTime               @default(now())
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]

  @@index([userId])
}

model FinancialTransaction {
  id               String         @id @default(uuid())
  bankConnectionId String
  amount           Float
  currency         String         @default("EUR")
  type             String
  category         String
  status           String         @default("COMPLETED")
  description      String?
  timestamp        DateTime       @default(now())
  bankConnection   BankConnection @relation(fields: [bankConnectionId], references: [id], onDelete: Cascade)

  @@index([bankConnectionId])
}

model AgentDossier {
  id        String   @id @default(uuid())
  agentType String
  action    String
  target    String?
  status    String   @default("SUCCESS")
  details   String?
  timestamp DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([agentType])
  @@index([userId])
}

model ShopifyStore {
  id           String           @id @default(uuid())
  userId       String
  shopUrl      String
  accessToken  String
  status       String           @default("ACTIVE")
  totalRevenue Float            @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  products     ShopifyProduct[]

  @@unique([userId, shopUrl])
}

model ShopifyProduct {
  id          String       @id @default(uuid())
  storeId     String
  shopifyId   String       @unique
  title       String
  description String?
  price       Float
  margin      Float?
  status      String       @default("DRAFT")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  store       ShopifyStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model SocialMediaPost {
  id        String   @id @default(uuid())
  userId    String
  platform  String
  content   String
  mediaUrl  String?
  status    String   @default("SCHEDULED")
  publishAt DateTime
  views     Int      @default(0)
  engagement Float   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model InterceptionAlert {
  id           String   @id @default(uuid())
  targetUserId String
  triggerType  String
  metrics      String
  status       String   @default("UNREAD")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  targetUser   User     @relation("TargetedUser", fields: [targetUserId], references: [id])

  @@index([targetUserId])
}

model TreasuryVault {
  id              String   @id @default(uuid())
  userId          String
  balance         Float    @default(0)
  reservedRiskCap Float    @default(0)
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TaxStrategy {
  id              String   @id @default(uuid())
  userId          String
  potName         String
  allocatedAmount Float    @default(0)
  taxAdvantage    Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CreditorDossier {
  id               String   @id @default(uuid())
  userId           String
  creditorName     String
  dossierNumber    String
  encryptedData    String
  status           String   @default("SCANNING")
  monthlyRepayment Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LegalContact {
  id               String    @id @default(uuid())
  userId           String
  organizationName String
  contactType      String
  municipality     String?
  email            String?
  phone            String?
  encryptedNotes   String?
  trustScore       Int       @default(50)
  lastContactedAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model JusticeLedger {
  id                String   @id @default(uuid())
  userId            String
  actionType        String
  description       String
  amount            Float?
  cryptographicHash String
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GoalDossier {
  id            String   @id @default(uuid())
  userId        String
  title         String
  targetAmount  Float
  currentAmount Float    @default(0)
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmergencyRequest {
  id               String   @id @default(uuid())
  userId           String
  encryptedReason  String
  requestedAmount  Float
  status           String   @default("PENDING_CEO_APPROVAL")
  aiAnalysis       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OpportunityReport {
  id        String             @id @default(uuid())
  userId    String
  title     String
  niche     String
  summary   String
  goodROI   Float
  betterROI Float
  bestROI   Float
  status    String             @default("REVIEW")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  media     OpportunityMedia[]

  @@index([userId])
}

model OpportunityMedia {
  id               String            @id @default(uuid())
  reportId         String
  platform         String
  mediaUrl         String
  mediaType        String
  adCopy           String
  status           String            @default("GENERATED")
  performanceScore Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  report           OpportunityReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model MarketingCampaign {
  id          String                @id @default(uuid())
  name        String
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  clicks      MarketingClick[]
  conversions MarketingConversion[]

  @@index([utmSource])
}

model MarketingClick {
  id         String            @id @default(uuid())
  campaignId String
  ipAddress  String?
  userAgent  String?
  referer    String?
  clickedAt  DateTime          @default(now())
  campaign   MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

model MarketingConversion {
  id          String            @id @default(uuid())
  campaignId  String
  userId      String?
  value       Float             @default(0)
  currency    String            @default("EUR")
  convertedAt DateTime          @default(now())
  campaign    MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([userId])
}

model AIConciergeLog {
  id              String   @id @default(uuid())
  userId          String
  decisionType    String
  rationale       String
  previousVtlb    Float?
  newVtlb         Float?
  confidenceScore Float    @default(0)
  status          String   @default("APPLIED")
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WebhookEvent {
  id           String    @id @default(uuid())
  provider     String
  eventId      String    @unique
  eventType    String
  payload      String
  status       String    @default("PENDING")
  errorMessage String?
  createdAt    DateTime  @default(now())
  processedAt  DateTime?

  @@index([provider])
  @@index([status])
}
