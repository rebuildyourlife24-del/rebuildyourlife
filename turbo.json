{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "globalEnv": [
    "DATABASE_URL",
    "DIRECT_URL",
    "JWT_SECRET",
    "NEXT_PUBLIC_API_URL",
    "NODE_ENV",
    "OPENAI_API_KEY",
    "GOOGLE_GENERATIVE_AI_API_KEY",
    "GROQ_API_KEY",
    "RESEND_API_KEY",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "CEREBRAS_API_KEY_1",
    "CEREBRAS_API_KEY_2",
    "CEREBRAS_API_KEY_3",
    "GROQ_API_KEY_1",
    "GROQ_API_KEY_2",
    "GROQ_API_KEY_3",
    "GEMINI_API_KEY_3",
    "MOLLIE_API_KEY",
    "MOLLIE_CLIENT_ID",
    "MOLLIE_CLIENT_SECRET",
    "next_publuc_supabase_url",
    "anon_public",
    "FORCE_OFFLINE_AI",
    "OLLAMA_MODEL",
    "ELEVENLABS_API_KEY",
    "TELEGRAM_BOT_TOKEN",
    "TELEGRAM_BOT_USERNAME",
    "SHOPIFY_ADMIN_ACCESS_TOKEN",
    "FIRECRAWL_API_KEY",
    "PINECONE_API_KEY",
    "PINECONE_INDEX_NAME",
    "MAKE_WEBHOOK_URL",
    "SHOPIFY_STORE_DOMAIN",
    "SHOPIFY_STOREFRONT_ACCESS_TOKEN"
  ],
  "tasks": {
    "dev": { "cache": false, "persistent": true },
    "build": { "dependsOn": ["^build"], "outputs": [".next/**", "dist/**"] },
    "lint": { "dependsOn": ["^build"] },
    "test": { "dependsOn": ["^build"] },
    "db:generate": { "cache": false },
    "db:push": { "cache": false },
    "db:migrate": { "cache": false },
    "clean": { "cache": false }
  }
}