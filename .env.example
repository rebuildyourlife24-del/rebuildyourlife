# ============================================================
# REBUILDYOURLIFE MONOREPO — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env files with real credentials.
# ============================================================

# ── DATABASE (Supabase PostgreSQL — eu-west-1) ──────────────
# Use the pooled connection for app queries
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use direct connection for Prisma migrations
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# ── AUTHENTICATION ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="GENERATE_64_CHAR_RANDOM_HEX"
JWT_REFRESH_SECRET="GENERATE_ANOTHER_64_CHAR_RANDOM_HEX"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── AI SERVICES ──────────────────────────────────────────────
OPENAI_API_KEY="sk-proj-REPLACE"
OPENAI_MODEL="gpt-4o"
GOOGLE_GENERATIVE_AI_API_KEY="REPLACE_WITH_GEMINI_KEY"

# ── REDIS (optional — for rate limiting / caching) ───────────
# REDIS_URL="redis://localhost:6379"
# UPSTASH_REDIS_REST_URL="https://REPLACE.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="REPLACE"

# ── APPLICATION URLS ─────────────────────────────────────────
NODE_ENV="development"
API_PORT=5000
API_URL="http://localhost:5000"
NEXT_PUBLIC_API_URL="http://localhost:5000/api/v1"
FRONTEND_URL="http://localhost:3000"

# Production:
# API_URL="https://rebuildyourlife123.onrender.com"
# NEXT_PUBLIC_API_URL="https://rebuildyourlife123.onrender.com/api/v1"
# FRONTEND_URL="https://app.rebuildyourlife.eu"

# ── PAYMENT PROVIDERS ────────────────────────────────────────
MOLLIE_API_KEY="test_REPLACE"
# STRIPE_SECRET_KEY="sk_test_REPLACE"
# STRIPE_WEBHOOK_SECRET="whsec_REPLACE"

# ── EMAIL (SMTP) ─────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
FROM_EMAIL="noreply@rebuildyourlife.eu"
